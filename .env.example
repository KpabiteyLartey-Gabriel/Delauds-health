# MongoDB connection (use TLS in production Atlas URI)
MONGODB_URI=mongodb://127.0.0.1:27017/gh-hotel

# JWT signing secret — use a long random string (≥32 chars). Never commit real secrets.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Optional: fail startup in production if JWT_SECRET is weak (handled in code)
# NODE_ENV=production
