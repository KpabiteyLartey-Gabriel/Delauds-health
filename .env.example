# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hoteldb

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long

# Cloudinary (ID Photo Storage)
# Get these from your Cloudinary dashboard: https://dashboard.cloudinary.com/settings/api
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App URL (used to build callback URLs in development/production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paystack
# Secret key from Paystack dashboard: Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
# Optional override. If not set, app uses NEXT_PUBLIC_APP_URL + /api/payments/paystack/callback
PAYSTACK_CALLBACK_URL=http://localhost:3000/api/payments/paystack/callback

# SMTP (used for cash payment confirmation emails)
SMTP_HOST=smtp.yourmailhost.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@waterhouselodge.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=Waterhouse Lodge <noreply@waterhouselodge.com>

# Admin recipient for cash payment confirmations
ADMIN_CASH_NOTIFICATION_EMAIL=info@waterhouseloadge.com
